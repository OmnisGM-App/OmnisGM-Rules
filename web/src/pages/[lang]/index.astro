---
import ReaderShell from '../../components/ReaderShell.astro';
import { nodeById, routeOf, isGroup, type Lang } from '../../lib/nav';

export async function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'ru' } }];
}

const lang = Astro.params.lang as Lang;
const t = (ru: string, en: string) => (lang === 'en' ? en : ru);

const REPO = 'https://github.com/OmnisGM-App/OmnisGM-Rules';
const ISSUE = `${REPO}/issues/new`;

// Маршрут на первую страницу версии (Legal) / документа
const r = (id: string) => {
  const n = nodeById(id);
  return n && !isGroup(n) ? routeOf(n.slug, lang) : `/${lang}`;
};

const title = t('Главная · OmnisGM Rules', 'Home · OmnisGM Rules');
const description = t(
  'Открытый свод свободно-лицензированных SRD настольных ролевых игр (D&D, Daggerheart, Basic Roleplaying) в Markdown, EN/RU. Проект экосистемы OmnisGM.',
  'Freely-licensed tabletop RPG System Reference Documents (D&D, Daggerheart, Basic Roleplaying) as Markdown, EN/RU. A project of the OmnisGM ecosystem.',
);

// Заголовки для TOC (контент авторский, не из Markdown)
const headings = [
  { depth: 2, slug: 'dnd', text: 'Dungeons & Dragons' },
  { depth: 2, slug: 'daggerheart', text: 'Daggerheart' },
  { depth: 2, slug: 'brp', text: 'Basic Roleplaying' },
];
---
<ReaderShell lang={lang} currentId="home" title={title} description={description} headings={headings}>
  <h1 id="ttrpg-srd">{t('TTRPG SRD — правила настольных ролёвок', 'TTRPG SRD — tabletop rules')}</h1>
  <p>
    {t(
      'Свободно доступные System Reference Document, собранные в одном месте, в Markdown, переведённые на русский и английский. Читайте онлайн или берите исходный текст.',
      'Freely-licensed System Reference Documents, gathered in one place, as Markdown, translated into English and Russian. Read online or take the source text.',
    )}
  </p>

  <h2 id="dnd">Dungeons &amp; Dragons</h2>
  <ul>
    <li><a href={r('d52-legal')}><strong>SRD 5.2.1</strong></a> — {t('базовые правила D&D 5e (2024): классы, заклинания, монстры, магические предметы, снаряжение. Лицензия CC BY 4.0.', 'the core rules of D&D 5e (2024): classes, spells, monsters, magic items, equipment. CC BY 4.0.')}</li>
    <li><a href={r('d51-legal')}><strong>SRD 5.1</strong></a> — {t('базовые правила D&D 5e (2014). Лицензия CC BY 4.0.', 'the core rules of D&D 5e (2014). CC BY 4.0.')}</li>
    <li><a href={r('d52-converting')}><strong>{t('Конвертация в SRD 5.2.1', 'Converting to SRD 5.2.1')}</strong></a> — {t('гайд по переходу с 5.1 на 5.2.1.', 'a guide to moving from 5.1 to 5.2.1.')}</li>
  </ul>

  <h2 id="daggerheart">Daggerheart</h2>
  <ul>
    <li><a href={r('dh-legal')}><strong>SRD 1.0</strong></a> — {t('правила Daggerheart: классы, домены, происхождения, противники, оружие, броня. Лицензия DPCGL. © 2025 Critical Role LLC.', 'the Daggerheart rules: classes, domains, ancestries, adversaries, weapons, armor. DPCGL. © 2025 Critical Role LLC.')}</li>
  </ul>

  <h2 id="brp">Basic Roleplaying</h2>
  <ul>
    <li><a href={r('brp-legal')}><strong>SRD 1.0</strong></a> — {t('универсальная d100-система от Chaosium (ядро Call of Cthulhu, RuneQuest и др.). Лицензия BRP OGL.', 'Chaosium’s universal d100 system (the engine behind Call of Cthulhu, RuneQuest and more). BRP OGL.')}</li>
  </ul>

  <hr />
  <blockquote>
    {t('Перевод на русский выполнен с помощью ИИ и вычитывается. Нашли ошибку — ', 'The translation is produced with AI assistance and is being proofread. Found an error? ')}
    <a href={ISSUE} target="_blank" rel="noopener">{t('создайте issue', 'Open an issue')}</a>
    {t(' в репозитории проекта.', ' in the project repository.')}
  </blockquote>
</ReaderShell>
